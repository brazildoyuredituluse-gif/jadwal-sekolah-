# Salin file ini menjadi ".env" lalu isi nilai aslinya.
# JANGAN PERNAH commit file ".env" ke Git — hanya file .env.example ini yang boleh dibagikan.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=school_schedule_user
DB_PASSWORD=ganti_dengan_password_kuat
DB_NAME=school_schedule

# --- Keamanan ---
# JWT_SECRET wajib string acak panjang (minimal 32 karakter).
# Generate contoh: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti_dengan_string_acak_minimal_32_karakter
JWT_EXPIRES_IN=2h

# Domain frontend yang diizinkan mengakses API (pisahkan dengan koma jika lebih dari satu).
# Kosongkan saat development lokal.
ALLOWED_ORIGINS=https://jadwal.smkn1cilamaya.sch.id
